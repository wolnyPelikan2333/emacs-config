(defun my/dashboard-open-same-window (path)
  "Open PATH in the same window, killing other windows first."
  (interactive)
  (when (> (count-windows) 1)
    (delete-other-windows))
  (if (file-directory-p path)
      (dired path)
    (find-file path)))


(use-package dashboard
  :ensure t
  :init
  (setq dashboard-set-navigator t)
  (setq initial-scratch-message nil)
  (setq dashboard-startup-banner "~/.config/emacs/images/dtmacs-logo.png")

  ;; AGENDA (info)
  (setq dashboard-items '((agenda . 10)))

  ;; PRZYCISKI / LINKI (DZIAŁAJĄ ZAWSZE)
  (setq dashboard-navigator-buttons
        `(((nil
            "NixOS config"
            "Open NixOS configuration"
            (lambda (&rest _)
              (my/dashboard-open-same-window
               "/etc/nixos/nixos/configuration.nix")))

           (nil
            "Home Manager"
            "Open Home Manager config"
            (lambda (&rest _)
              (my/dashboard-open-same-window
               "/etc/home/michal.nix")))

           (nil
            "Emacs init.el"
            "Open init.el"
            (lambda (&rest _)
              (my/dashboard-open-same-window
               "~/.emacs.d/init.el")))

           (nil
            "Mapa – skróty"
            "Open skróty.org"
            (lambda (&rest _)
              (my/dashboard-open-same-window
               "~/mapa/skróty.org")))

           (nil
            "Mapa (Dired)"
            "Open mapa directory"
            (lambda (&rest _)
              (my/dashboard-open-same-window
               "~/mapa"))))))

  :config
  (dashboard-setup-startup-hook))


