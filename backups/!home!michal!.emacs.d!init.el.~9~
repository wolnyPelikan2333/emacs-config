(defun nix-format-buffer ()
  "Format current buffer using alejandra or nixfmt."
  (interactive)
  (when (eq major-mode 'nix-mode)
    (shell-command-on-region
     (point-min)
     (point-max)
     "alejandra"
     (current-buffer)
     t)))

